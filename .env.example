# ===========================
# DCC Liquid Staking Protocol
# ===========================

# Network: testnet | mainnet
NETWORK=testnet

# Node URL
DCC_NODE_URL=https://testnode1.decentralchain.io

# Chain ID (T = testnet, D = mainnet for DecentralChain)
DCC_CHAIN_ID=T

# dApp account seed (NEVER commit real seeds)
DAPP_SEED=your-testnet-seed-phrase-here

# Admin address
ADMIN_ADDRESS=3N...

# Operator address
OPERATOR_ADDRESS=3N...

# Treasury address
TREASURY_ADDRESS=3N...

# Protocol fee in basis points (e.g., 1000 = 10%)
PROTOCOL_FEE_BPS=1000

# Minimum deposit in wavelets (1 DCC = 100000000)
MIN_DEPOSIT_DCC=100000000

# Minimum withdrawal shares
MIN_WITHDRAW_SHARES=100000000

# ===========================
# Indexer
# ===========================
DATABASE_URL=postgresql://localhost:5432/dcc_staking
INDEXER_PORT=3001
INDEXER_POLL_INTERVAL_MS=5000

# ===========================
# Operator
# ===========================
OPERATOR_POLL_INTERVAL_MS=30000
OPERATOR_SEED=your-operator-seed-phrase-here

# ===========================
# Frontend
# ===========================
NEXT_PUBLIC_DCC_NODE_URL=https://testnode1.decentralchain.io
NEXT_PUBLIC_DAPP_ADDRESS=3N...
NEXT_PUBLIC_STDCC_ASSET_ID=
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001
